<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

<div class="container">

<h2>Book Store</h2>

<a href="/books/add" class="btn btn-primary">Add Book</a>

<% if(message){ %>

<div class="alert alert-success mt-2">
<%= message %>
</div>

<% } %>

<form class="row mt-3">

<div class="col">
<input name="search" class="form-control" placeholder="Search">
</div>

<div class="col">
<select name="category" class="form-control">
<option value="">All</option>
<option>Programming</option>
<option>Database</option>
<option>Networking</option>
<option>AI</option>
</select>
</div>

<div class="col">
<button class="btn btn-secondary">Filter</button>
</div>

</form>

<table class="table mt-3">

<tr>
<th>Image</th>
<th>Title</th>
<th>Category</th>
<th>Price</th>
<th>Stock</th>
<th>Inventory</th>
<th>Action</th>
</tr>

<% books.forEach(book=>{ %>

<tr>

<td>
<img src="<%=book.coverImageUrl%>" width="70">
</td>

<td><%=book.title%></td>

<td><%=book.category%></td>

<td><%=book.price%></td>

<td><%=book.unit_in_stock%></td>

<td><%=book.inventoryValue%></td>

<td>

<a href="/books/edit/<%=book.bookId%>" class="btn btn-warning btn-sm">Edit</a>

<form action="/books/delete/<%=book.bookId%>" method="POST"
onsubmit="return confirm('Delete this book?')"
style="display:inline">

<button class="btn btn-danger btn-sm">Delete</button>

</form>

</td>

</tr>

<% }) %>

</table>

</div>