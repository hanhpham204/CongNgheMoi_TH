<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

<div class="container">

<h2>Edit Book</h2>

<form action="/books/edit/<%=book.bookId%>"
method="POST"
enctype="multipart/form-data">

<input name="price"
value="<%=book.price%>"
class="form-control mb-2">

<input name="unit_in_stock"
value="<%=book.unit_in_stock%>"
class="form-control mb-2">

<select name="category" class="form-control mb-2">

<option <%=book.category=="Programming"?"selected":""%>>Programming</option>
<option <%=book.category=="Database"?"selected":""%>>Database</option>
<option <%=book.category=="Networking"?"selected":""%>>Networking</option>
<option <%=book.category=="AI"?"selected":""%>>AI</option>

</select>

<input type="file" name="image" class="form-control mb-2">

<button class="btn btn-warning">Update</button>

<a href="/books" class="btn btn-secondary">Back</a>

</form>

</div>