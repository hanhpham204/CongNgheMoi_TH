<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

<div class="container">

<h2>Add Book</h2>

<form action="/books/add"
method="POST"
enctype="multipart/form-data">

<div class="mb-3">

<label>Title</label>

<input name="title"
value="<%= old?.title || '' %>"
class="form-control">

<div class="text-danger">
<%= errors?.title %>
</div>

</div>


<div class="mb-3">

<label>Category</label>

<select name="category"
class="form-control">

<option value="">Select category</option>

<option
<%= old?.category=="Programming"?"selected":"" %>>
Programming
</option>

<option
<%= old?.category=="Database"?"selected":"" %>>
Database
</option>

<option
<%= old?.category=="Networking"?"selected":"" %>>
Networking
</option>

<option
<%= old?.category=="AI"?"selected":"" %>>
AI
</option>

</select>

<div class="text-danger">
<%= errors?.category %>
</div>

</div>


<div class="mb-3">

<label>Price</label>

<input name="price"
value="<%= old?.price || '' %>"
class="form-control">

<div class="text-danger">
<%= errors?.price %>
</div>

</div>


<div class="mb-3">

<label>Stock</label>

<input name="unit_in_stock"
value="<%= old?.unit_in_stock || '' %>"
class="form-control">

<div class="text-danger">
<%= errors?.unit_in_stock %>
</div>

</div>


<div class="mb-3">

<label>Image</label>

<input type="file"
name="image"
class="form-control">

</div>


<button class="btn btn-success">
Add Book
</button>

<a href="/books"
class="btn btn-secondary">
Back
</a>

</form>

</div>