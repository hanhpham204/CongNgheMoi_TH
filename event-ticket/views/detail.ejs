<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container py-4">
  <div class="card shadow-sm border-0 bg-info-subtle mx-auto" style="max-width: 760px;">
    <div class="card-body">
      <h2 class="h4 mb-4">Chi tiết vé</h2>

      <div class="row g-3">
        <div class="col-12 col-md-6"><strong>Event:</strong> <%= item.eventName %></div>
        <div class="col-12 col-md-6"><strong>Holder:</strong> <%= item.holderName %></div>
        <div class="col-12 col-md-6"><strong>Total:</strong> <%= item.totalAmount %></div>
        <div class="col-12 col-md-6"><strong>Final:</strong> <%= item.finalAmount %></div>
        <div class="col-12 col-md-6"><strong>Status:</strong> <span class="badge text-bg-info"><%= item.status %></span></div>
        <div class="col-12 col-md-6"><strong>Label:</strong> <%= item.label %></div>
      </div>

      <% if (item.imageUrl) { %>
        <img src="<%= item.imageUrl %>" alt="Ticket image" class="img-fluid rounded border mt-4" />
      <% } %>

      <a href="/" class="btn btn-primary mt-4">Quay về</a>
    </div>
  </div>
</div>