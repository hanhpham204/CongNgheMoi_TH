<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container py-4">
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h2 class="h4 text-center mb-4">DANH SÁCH VÉ SỰ KIỆN</h2>

            <form method="GET" class="row g-2 align-items-center mb-4">
                <div class="col-12 col-md-4">
                    <input class="form-control" name="keyword" placeholder="Search..." value="<%= keyword || '' %>" />
                </div>
                <div class="col-12 col-md-3">
                    <select class="form-select" name="status">
                        <option value="" <%=!status ? 'selected' : '' %>>All</option>
                        <option value="Upcoming" <%=status==='Upcoming' ? 'selected' : '' %>>Upcoming</option>
                        <option value="Sold" <%=status==='Sold' ? 'selected' : '' %>>Sold</option>
                        <option value="Cancelled" <%=status==='Cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">Tìm</button>
                </div>
                <div class="col-auto ms-md-auto">
                    <a href="/add" class="btn btn-secondary">+ Thêm sự kiện</a>
                </div>
            </form>

            <div class="row g-3">
                <% items.forEach(i=> { %>
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card h-100 border bg-warning-subtle">
                            <% if (i.imageUrl) { %>
                                <img src="<%= i.imageUrl %>" alt="Ticket image" class="card-img-top" style="object-fit: cover; height: 180px;" />
                            <% } %>
                            <div class="card-body">
                                <p class="mb-2"><strong>Event:</strong> <%= i.eventName %></p>
                                <p class="mb-2"><strong>Holder:</strong> <%= i.holderName %></p>
                                <p class="mb-2"><strong>Total:</strong> <%= i.totalAmount %> vnđ</p>
                                <p class="mb-2"><strong>Final:</strong> <%= i.finalAmount %> vnđ</p>
                                <p class="mb-2"><strong>Status:</strong> <span class="badge text-bg-info"><%= i.status %></span></p>
                                <p class="mb-3"><strong>Label:</strong> <%= i.label %></p>
                                <div class="d-flex gap-2">
                                    <a href="/detail/<%= i.ticketId %>" class="btn btn-outline-primary btn-sm">Xem</a>
                                    <a href="/edit/<%= i.ticketId %>" class="btn btn-outline-success btn-sm">Sửa</a>
                                    <a href="/delete/<%= i.ticketId %>" class="btn btn-outline-danger btn-sm">Xóa</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>
</div>