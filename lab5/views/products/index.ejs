<!DOCTYPE html>
<html>
<head>
  <title>Products</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="container mt-4">

<h3>Product List</h3>

<!-- SEARCH -->
<form method="GET" action="/products" class="mb-3">
  <input type="text" name="keyword" class="form-control" placeholder="Search...">
</form>

<!-- ADD -->
<a href="/products/create" class="btn btn-primary mb-3">Add Product</a>

<table class="table table-bordered">
  <tr>
    <th>Name</th>
    <th>Price</th>
    <th>Image</th>
    <th>Action</th>
  </tr>

  <% products.forEach(p => { %>
    <tr>
      <td><%= p.name %></td>
      <td><%= p.price %></td>
      <td>
        <% if(p.url_image){ %>
          <img src="<%= p.url_image %>" width="60">
        <% } %>
      </td>
      <td>
        <a href="/products/edit/<%= p.id %>" class="btn btn-warning btn-sm">Edit</a>

        <form action="/products/<%= p.id %>?_method=DELETE" method="POST" style="display:inline">
          <button class="btn btn-danger btn-sm">Delete</button>
        </form>
      </td>
    </tr>
  <% }) %>

</table>

</body>
</html>