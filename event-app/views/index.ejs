<!DOCTYPE html>
<html>
<head>
  <title>Danh sách vé</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="container mt-4">

<h2 class="mb-4">Danh sách vé sự kiện</h2>

<a href="/tickets/add" class="btn btn-primary mb-3">Thêm vé</a>

<table class="table table-bordered table-striped">
  <thead class="table-dark">
    <tr>
      <th>Mã vé</th>
      <th>Sự kiện</th>
      <th>Giá</th>
      <th>Số lượng</th>
      <th>Ảnh</th>
      <th>Hành động</th>
    </tr>
  </thead>

  <tbody>
    <% tickets.forEach(ticket => { %>
      <tr>
        <td><%= ticket.ticketId %></td>
        <td><%= ticket.eventName %></td>
        <td><%= ticket.price %></td>
        <td><%= ticket.quantity %></td>

        <td>
          <% if(ticket.imageUrl){ %>
            <img src="<%= ticket.imageUrl %>" width="80">
          <% } %>
        </td>

        <td>
          <a href="/tickets/edit/<%= ticket.ticketId %>" class="btn btn-warning btn-sm">Sửa</a>

          <a href="/tickets/delete/<%= ticket.ticketId %>"
             class="btn btn-danger btn-sm"
             onclick="return confirm('Xóa vé này?')">
             Xóa
          </a>
        </td>
      </tr>
    <% }) %>
  </tbody>

</table>

</body>
</html>