<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Room</title>
    <link rel="stylesheet" href="/css/rooms.css" />
  </head>
  <body>
    <div class="container">
      <h1>Edit Room</h1>
      <p class="subtitle">Update price, capacity, status and image</p>

      <% if (error) { %>
      <div class="alert error"><%= error %></div>
      <% } %>

      <section class="card">
        <h2><%= room.roomName %> (<%= room.roomType %>)</h2>

        <% if (room.imageUrl) { %>
        <img src="<%= room.imageUrl %>" alt="<%= room.roomName %>" class="room-image" />
        <% } %>

        <form
          action="/rooms/api/<%= room.roomId %>?_method=PUT"
          method="POST"
          enctype="multipart/form-data"
          class="grid-form"
        >
          <input
            type="number"
            name="pricePerNight"
            min="1"
            step="0.01"
            value="<%= room.pricePerNight %>"
            required
          />
          <input
            type="number"
            name="capacity"
            min="1"
            max="10"
            value="<%= room.capacity %>"
            required
          />
          <select name="status" required>
            <% allowedStatus.forEach((st) => { %>
            <option value="<%= st %>" <%= st === room.status ? "selected" : "" %>>
              <%= st %>
            </option>
            <% }) %>
          </select>
          <input type="file" name="image" accept="image/*" />
          <button type="submit">Save Changes</button>
        </form>
      </section>

      <div class="top-actions">
        <a href="/rooms" class="btn-link">Back to room list</a>
      </div>
    </div>
  </body>
</html>
