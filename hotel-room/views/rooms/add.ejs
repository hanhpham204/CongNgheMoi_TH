<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Room</title>
    <link rel="stylesheet" href="/css/rooms.css" />
  </head>
  <body>
    <div class="container">
      <h1>Add New Room</h1>
      <p class="subtitle">Create a new room and upload image to S3</p>

      <% if (error) { %>
      <div class="alert error"><%= error %></div>
      <% } %>

      <section class="card">
        <form
          action="/rooms/api"
          method="POST"
          enctype="multipart/form-data"
          class="grid-form"
        >
          <input type="text" name="roomName" placeholder="Room name" required />
          <select name="roomType" required>
            <option value="">Choose room type</option>
            <% allowedTypes.forEach((type) => { %>
            <option value="<%= type %>"><%= type %></option>
            <% }) %>
          </select>
          <input
            type="number"
            name="pricePerNight"
            min="1"
            step="0.01"
            placeholder="Price per night"
            required
          />
          <input
            type="number"
            name="capacity"
            min="1"
            max="10"
            placeholder="Capacity (1-10)"
            required
          />
          <select name="status" required>
            <% allowedStatus.forEach((st) => { %>
            <option value="<%= st %>"><%= st %></option>
            <% }) %>
          </select>
          <input type="file" name="image" accept="image/*" />
          <button type="submit">Add Room</button>
        </form>
      </section>

      <div class="top-actions">
        <a href="/rooms" class="btn-link">Back to room list</a>
      </div>
    </div>
  </body>
</html>
