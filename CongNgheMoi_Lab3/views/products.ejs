<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Product Management</title>

  <!-- Bootstrap 5 CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background-color: #f8f9fa;
    }
    .card {
      border-radius: 12px;
    }
    img {
      object-fit: cover;
    }
  </style>
</head>
<body>

<div class="container mt-5">

  <h2 class="text-center mb-4">Product Management</h2>

  <div class="row">
    <!-- FORM ADD PRODUCT -->
    <div class="col-md-4">
      <div class="card shadow-sm">
        <div class="card-body">
          <h5 class="card-title mb-3">Add Product</h5>

          <form action="/create" method="POST" enctype="multipart/form-data">
            <div class="mb-3">
              <label class="form-label">Product Name</label>
              <input name="name" class="form-control" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Price</label>
              <input name="price" type="number" class="form-control" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Quantity</label>
              <input name="quantity" type="number" class="form-control" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Product Image</label>
              <input name="image" type="file" class="form-control" accept="image/*" required>
            </div>

            <button class="btn btn-primary w-100">Add Product</button>
          </form>
        </div>
      </div>
    </div>

    <!-- PRODUCT TABLE -->
    <div class="col-md-8">
      <div class="card shadow-sm">
        <div class="card-body">
          <h5 class="card-title mb-3">Product List</h5>

          <table class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
              <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Price</th>
                <th>Quantity</th>
                <th width="160">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (products.length === 0) { %>
                <tr>
                  <td colspan="5" class="text-center">No products found</td>
                </tr>
              <% } %>

              <% products.forEach(p => { %>
                <tr>
                  <td>
                    <img src="<%= p.url_image %>" width="80" height="80">
                  </td>
                  <td><%= p.name %></td>
                  <td><%= p.price %></td>
                  <td><%= p.quantity %></td>
                  <td>
                    <a href="/edit/<%= p.id %>" class="btn btn-sm btn-warning">Edit</a>
                    <a href="/delete/<%= p.id %>"
                       class="btn btn-sm btn-danger"
                       onclick="return confirm('Are you sure?')">
                       Delete
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>

        </div>
      </div>
    </div>
  </div>

</div>

</body>
</html>
